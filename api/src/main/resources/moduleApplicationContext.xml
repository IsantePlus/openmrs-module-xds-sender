<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns="http://www.springframework.org/schema/beans" xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
  		    http://www.springframework.org/schema/beans/spring-beans-4.1.xsd http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.1.xsd">
<context:annotation-config />

<context:component-scan base-package="org.openmrs.module.xdssender"/>

    <bean id="xdsSender.XdsExportService" class="org.openmrs.module.xdssender.api.service.impl.XdsExportServiceImpl">
        <property name="clinicalDocBuilder" ref="xdsender.ClinicalDocumentBuilder" />
        <property name="ormDocBuilder" ref="ORM_O01DocumentBuilder" />
        <property name="fhirResourceBuilder" ref="fhirResourceDocumentBuilder" />
        <property name="messageUtil" ref="xdssender.MessageUtil" />
        <property name="config" ref="xdssender.XdsSenderConfig" />
        <property name="xdsSender" ref="xdssender.XdsSender" />
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.xdssender.api.service.XdsExportService</value>
                <ref bean="xdsSender.XdsExportService" />
            </list>
        </property>
    </bean>

    <bean id="fhirResourceDocumentBuilder" class="org.openmrs.module.xdssender.api.fhir.FhirResourceDocumentBuilderImpl">
        <property name="cdaDataUtil" ref="xdssender.CdaDataUtil" />
        <property name="patientTranslator" ref="patientTranslatorImpl" />
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.xdssender.api.fhir.FhirResourceDocumentBuilder</value>
                <ref bean="fhirResourceDocumentBuilder"/>
            </list>
        </property>
    </bean>
</beans>
